{
	"info": {
		"name": "API Ginásio de Escalada",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Login (Gera Token)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if(jsonData.token) { pm.collectionVariables.set(\"jwt_token\", jsonData.token); }"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"admin@ginasioescalada.com\",\n    \"senha\": \"hfali7ta@gf!\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "http://localhost:3000/api/auth/login",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3000",
					"path": ["api", "auth", "login"]
				}
			}
		},
		{
			"name": "2. Listar Rotas (Paginação e Filtros)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [ { "key": "token", "value": "{{jwt_token}}", "type": "string" } ]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3000/api/rotas?page=1&limit=5&grau=V3",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3000",
					"path": ["api", "rotas"],
					"query": [
						{ "key": "page", "value": "1" },
						{ "key": "limit", "value": "5" },
						{ "key": "grau", "value": "V3" }
					]
				}
			}
		},
		{
			"name": "3. Criar Rota",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [ { "key": "token", "value": "{{jwt_token}}", "type": "string" } ]
				},
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"nome\": \"Salto de Fé\",\n    \"grau\": \"V7\",\n    \"corAgarras\": \"Verde Neon\",\n    \"routeSetter\": \"Marcos\",\n    \"setorId\": 1\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "http://localhost:3000/api/rotas",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3000",
					"path": ["api", "rotas"]
				}
			}
		}
	],
	"variable": [
		{ "key": "jwt_token", "value": "", "type": "string" }
	]
}